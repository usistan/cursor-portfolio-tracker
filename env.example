# E*TRADE Developer Portal: https://developer.etrade.com/getting-started
# Sandbox-Key: https://us.etrade.com/etx/ris/apikey — Produktion: Secure Message an E*TRADE

ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
# true = Sandbox-Keys (OAuth + API: apisb.etrade.com), false = Produktion (api.etrade.com)
ETRADE_SANDBOX=false
# Pfad zur Token-Datei (chmod 600)
ETRADE_TOKEN_PATH=.etrade_tokens.json

# Charles Schwab Developer (OAuth 2.0, schwab-py): https://developer.schwab.com/
# Callback-URL muss 1:1 mit der App im Portal übereinstimmen (z. B. https://127.0.0.1:8182)
SCHWAB_API_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=.schwab_token.json

# Interactive Brokers — Client Portal Web API (ibind), UK/US: gleiche Endpoints
# Standard: Client Portal Gateway lokal (Login im Browser), siehe https://www.interactivebrokers.com/campus/ibkr-api-page/cpapi-v1/
IBKR_GATEWAY_HOST=127.0.0.1
IBKR_GATEWAY_PORT=5000
# IBKR_BASE_ROUTE=/v1/api/
# IBKR_REST_URL=   # statt Host/Port, z. B. https://127.0.0.1:5000/v1/api/
# IBKR_ACCOUNT_ID=  # optional, sonst erste Konto-ID aus /portfolio/accounts
# Pfad zur Gateway-CA-Datei — leer lassen heißt: SSL-Verify aus (nur localhost)
# IBKR_CACERT=
# OAuth 1.0a (headless, ohne Gateway): IBKR_USE_OAUTH=true und IBIND_OAUTH1A_* / IBIND_USE_OAUTH siehe ibind-Doku
# IBKR_USE_OAUTH=false
