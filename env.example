# E*TRADE Developer Portal: https://developer.etrade.com/getting-started
# Sandbox-Key: https://us.etrade.com/etx/ris/apikey — Produktion: Secure Message an E*TRADE

ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
# true = Sandbox-Keys (OAuth + API: apisb.etrade.com), false = Produktion (api.etrade.com)
ETRADE_SANDBOX=false
# Pfad zur Token-Datei (chmod 600)
ETRADE_TOKEN_PATH=.etrade_tokens.json

# Charles Schwab Developer (OAuth 2.0, schwab-py): https://developer.schwab.com/
# Callback-URL muss 1:1 mit der App im Portal übereinstimmen (z. B. https://127.0.0.1:8182)
SCHWAB_API_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=.schwab_token.json
